---
import BaseLayout from '../layouts/BaseLayout.astro';
import SideBar from '../components/SideBar.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';

import { getCollection } from 'astro:content';
import ProjectTile from '../components/ProjectTile.astro';

import ProjectNumbers from '../components/ProjectNumbers.astro';
import GitHubActivity from '../components/GitHubActivity.astro';

const allProjects = await getCollection('projects');
const contentProjects = allProjects.filter(p => !p.data.spotlight)

const spotlightProject = allProjects.find(p => p.data.spotlight);
---

<BaseLayout pageTitle="Projects">
  <div class = "layout">
    <SideBar/>
    <NavBar/>
    <div class = main-container>
      <div class = main-content-wrapper>
        <div>
          <h1 class = retro-text>Projects</h1>
          <p class = hero-text>Here's some of the projects I've been working on!</p>
        </div>
        <div class = main-content-section>
          <div class = project-hero-grid>
            <ProjectNumbers />

            <div class = featured-project>
              {spotlightProject && 
              <ProjectTile 
                title={spotlightProject.data.title}
                description={spotlightProject.data.description}
                themeColor={spotlightProject.data.themeColor}
                slug={spotlightProject.id}
                liveUrl={spotlightProject.data.liveUrl}
                githubUrl={spotlightProject.data.githubUrl}
                detailsUrl={spotlightProject.data.detailsUrl}
                devpostUrl={spotlightProject.data.devpostUrl}
                image={spotlightProject.data.image}
                projectTags={spotlightProject.data.projectTags}
                featured={true}
              />
              }
            </div>
            <GitHubActivity />
          </div>
        </div>

        <div class = main-content-section>
          <div class="projects-grid">
            {contentProjects.map((project) => (
              <ProjectTile 
                title={project.data.title}
                description={project.data.description}
                themeColor={project.data.themeColor}
                slug={project.id} 
                liveUrl={project.data.liveUrl}
                githubUrl={project.data.githubUrl}
                detailsUrl={project.data.detailsUrl}
                devpostUrl={project.data.devpostUrl}
              />
            ))}
          </div>
        </div>
      </div>
      <Footer/>
    </div>
  </div>
</BaseLayout>

<style>
  h1{
    font-size: 3rem;
  }

  .project-hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto 1fr;
    column-gap: 1rem;
    row-gap: 1rem;
  }

  .featured-project {
    grid-column: 1;
    grid-row: 2;
    width: 100%;
  }

  @media ( max-width: 1024px ) {
    .project-hero-grid {
      grid-template-columns: repeat(auto-fit, minmax(min(350px, 100%), 1fr));
      grid-template-rows: auto;
    }

    .featured-project {
      grid-column: auto; 
      grid-row: auto;
    }
  }
</style>