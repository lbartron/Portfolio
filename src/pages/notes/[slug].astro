---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SideBar from '../../components/SideBar.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import 'katex/dist/katex.min.css'

export async function getStaticPaths() {
  const noteEntries = await getCollection('notes');

  return noteEntries.map(entry => {
    return {
      params: { slug: entry.id },
      props: { entry },
    };
  });
}

// Grab md file content and extract it
const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Only keep h2 and h3 for cleaner ToC
const tocHeadings = headings.filter((h) => h.depth > 1 && h.depth <= 3);

// Get word count and create time to read
const plainText: string = entry.body ?? "";

const cleanText = plainText
  .replace(/!\[.*?\]\(.*?\)/g, '') // Remove markdown images
  .replace(/\[.*?\]\(.*?\)/g, '')  // Remove markdown links
  .replace(/```[\s\S]*?```/g, '');  // Remove code blocks

// Get words
const words = cleanText.split(/\s+/).filter(word => word.length > 0);
const wordCount = words.length;
const ttr = Math.ceil(wordCount / 200);
---

<BaseLayout pageTitle={entry.data.title || "Note"}>
  <div class="layout">
    <SideBar />
    <NavBar/>
    <div class="main-container">
      <div class="main-content-wrapper note-page-wrapper">
        
        <!-- Left Side Note Content -->
        <article class="note-content">
          <header class="note-header">
            <h1>{entry.data.title || "Untitled Note"}</h1>
            <span class = description-wrapper>
              {entry.data.description && <p class="description">{entry.data.description}</p>}
              <p class = description>{ttr} Minute Read</p>
            </span>
          </header>
          
          <div class="markdown-content prose dark:prose-invert">
            <Content />
          </div>
        </article>

        <!-- Right Side TOC -->
        <aside class="note-sidebar">
          <div class="sticky-sidebar-content">
            <!-- Table of Contents -->
            {tocHeadings.length > 0 && (
              <div class="toc-container">
                <h3>On This Page</h3>
                <nav class="toc-nav">
                  <ul>
                    {tocHeadings.map((heading) => (
                      <li class={`toc-level-${heading.depth}`}>
                        <a href={`#${heading.slug}`}>{heading.text}</a>
                      </li>
                    ))}
                  </ul>
                </nav>
              </div>
            )}
          </div>
        </aside>

      </div>
      <Footer/>
    </div>
  </div>
  <script src="../../scripts/tocnav.js"></script>
</BaseLayout>

<style>
  /* Split the main wrapper into a 2-column grid for the note and sidebar */
  .note-content {
    min-width: 0; 
    width: 100%;
  }

  .note-page-wrapper {
    display: grid;
    /* grid-template-columns: 1fr 280px; */
    grid-template-columns: 4fr 1fr;
    gap: 3rem;
  }

  .note-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .note-header h1{
    font-size: 2.5rem;
  }

  .description {
    color: var(--text-muted);
  }

  .description-wrapper{
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    gap: 2rem;
  }

  .markdown-content {
    line-height: 1.6;
  }

  /* Sticky Right Sidebar */
  .sticky-sidebar-content {
    position: sticky;
    top: 2rem; /* How far from the top of the screen it sticks */
    max-height: calc(100vh - 40px);
    overflow-y: auto;
  }

  /* ToC Styling */  
  .toc-container h3 {
    font-size: 1.1rem;
    color: var(--retro-navy);
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .toc-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-nav li {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .toc-nav a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .toc-nav a:hover {
    color: var(--retro-orange);
  }

  .toc-nav a.active {
    color: var(--retro-orange);
  }

  /* Indent H3s slightly to show hierarchy */
  .toc-level-3 {
    padding-left: 1rem;
  }

  /* MD content styling */
  .markdown-content {
    line-height: 1.6;
    overflow-wrap: break-word;
    word-wrap: break-word;
    max-width: 100%;
  }

  /* Handle code blocks and math equations */
  .markdown-content pre, 
  .markdown-content .math {
    /* If a code block or equation is too wide give it an internal scrollbar */
    max-width: 100%;
    overflow-x: auto;
    
    /* Subtle border to indicate it's a scrollable container */
    border: 1px solid var(--border-color);
    border-radius: 4px;
  }
  
  .markdown-content img {
     max-width: 100%;
     height: auto;
  }

  /* Initial responsive design */
  @media (max-width: 1024px) {
    .note-page-wrapper {
      grid-template-columns: 1fr;
    }
    .note-sidebar {
      order: -1; /* Puts ToC/Graph above the note content on mobile */
      margin-bottom: 2rem;
    }
    .sticky-sidebar-content {
      position: relative;
      top: 0;
    }
  }
</style>