---
import BaseLayout from '../layouts/BaseLayout.astro';
import SideBar from '../components/SideBar.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';

// Get recent notes/projects
import { getCollection } from 'astro:content';
import ProjectTile from '../components/ProjectTile.astro';
import NoteTile from '../components/NoteTile.astro';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter(p => p.data.featured);

const allNotes = await getCollection('notes');
const sortedNotes = allNotes.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});
const recentNotes = sortedNotes.slice(0, 5);

import { Image } from 'astro:assets';
import homeImage from '../assets/images/HomeImage.jpg';
import projectsIcon from '/src/assets/images/projects.png';
import notesIcon from '/src/assets/images/notes.png';
import aboutIcon from '/src/assets/images/about-me.png';
---

<BaseLayout pageTitle="Home">
  <div class = "layout">
    <SideBar/>
    <NavBar/>
    <div class = main-container>
      <div class = main-content-wrapper>
        <div class = "hero">
          <div class = hero-text-container>
            <h1 class = retro-text>Hi, I'm Leo!</h1>
            <p class = hero-text>
              I'm a software engineer and student at UW Bothell building 
              <span class="highlight-blue"> intelligent systems </span> and 
              <span class="highlight-green"> local-first architecture </span>. 
            </p>
            <a href={`${import.meta.env.BASE_URL}about/`} class="retro-link">More About Me &rarr;</a>
            <p class = hero-text>
              I enjoy building projects with the goal of learning new things.
              This is some extra text to take up space in this section. 
              I need this so I can figure out proper page layouts
            </p>
          </div>
          <div class = hero-image-container>
            <img class = hero-image src={homeImage.src} alt="Hero Image">
          </div>
        </div>
        <div class = main-content-section>
          <span class = content-header>
            <Image src={projectsIcon} alt = "Projects image" class = "content-header-icon"/>
            <h2 class = flat-retro-text>Projects</h2>
          </span>
          <div class="projects-grid">
            {featuredProjects.map((project) => (
              <ProjectTile 
                title={project.data.title}
                description={project.data.description}
                themeColor={project.data.themeColor}
                slug={project.id} 
                liveUrl={project.data.liveUrl}
                githubUrl={project.data.githubUrl}
                detailsUrl={project.data.detailsUrl}
                devpostUrl={project.data.devpostUrl}
              />
            ))}
          </div>
        </div>
        <div class = main-content-section>
          <span class = content-header>
            <Image src={notesIcon} alt = "Notes image" class = "content-header-icon"/>
            <h2 class = flat-retro-text>Notes</h2>
          </span>
          <div class = note-list>
            {recentNotes.map((note) => (
              <NoteTile
                title = {note.data.title}
                description = {note.data.description}
                slug = {note.id}
                date = {note.data.date}
              />
            ))}
          </div>
        </div>
      </div>
      <Footer/>
    </div>
  </div>
</BaseLayout>


<style>
  .content-header {
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  .content-header-icon{
    margin-right: 10px;
    width: 48px;
    height: 48px;
  }

  .hero-text-container .retro-text {
    /* Scale from 2.2rem on mobile to 3.5rem on large desktops */
    font-size: clamp(2.2rem, 5vw + 1rem, 3.5rem);
    line-height: 1.1;
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .hero-text-container .hero-text {
    /* Scale body text to stay readable */
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.15rem);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .hero-text-container .retro-link {
    margin-bottom: 1.5rem;
  }

  .hero {
    display: flex;
    flex-direction: row;
    /* gap: 4rem; */
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .hero-text-container {
    flex: 1 1 50%; 
    min-width: 280px;
  }

  .hero-image-container {
    position: relative;
    flex: 0 0 auto;
    width: 100%;

    max-width: clamp(260px, 35%, 380px); 
    aspect-ratio: 1/1;
    z-index: 1;

    /* Styling like printed photo */
    padding: 12px 12px 35px 12px; /* Thick bottom border like a polaroid */
    background: light-dark(#fdfdfd, #d8d8d8); /* Physical paper color */
    border: 1px solid var(--border-color);
    box-shadow: 6px 6px 0px var(--retro-dark);
    transform: rotate(3deg); /* Photo card tilt */
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 2px solid transparent;
    border-radius: 8px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .hero-image:hover {
    transform: translateY(4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    border-color: var(--retro-dark);
  }

  /* Temporary media setting to stack grid tiles to 
     single column on small screens */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse; /* Puts text on top, image on bottom for mobile */
      gap: 2rem;
    }

    .hero-text-container {
      text-align: center;
      width: 100%;
    }
  
    .hero-image-container {
      /* flex: 0 0 auto;
      width: 100%; */

      max-width: clamp(250px, 70%, 350px);
      aspect-ratio: 1 / 1; 
      margin: 0 auto; /* Center the photo */
      transform: rotate(-2deg);
    }
  }
</style>