---
import BaseLayout from '../layouts/BaseLayout.astro';
import SideBar from '../components/SideBar.astro';
import Footer from '../components/Footer.astro';
// Get recent notes/projects here
---

<BaseLayout title="Home">
  <!-- Everything here gets injected into the <slot /> of BaseLayout -->
  <div class = "layout">
    <SideBar/>
    <div class = main-container>
      <div class = main-content-wrapper>
        <div class = "hero">
          <h1>Hi, I'm Leo!</h1>
          <p>This is a little information about me</p>
        </div>
        <div class = main-content-section>
          <h1>Projects</h1>
        </div>
        <div class = main-content-section>
          <h1>Notes</h1>
        </div>
      </div>
      <Footer/>
    </div>
  </div>
</BaseLayout>
