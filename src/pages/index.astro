---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToggleTheme from '../components/ToggleTheme.astro';
// Get recent notes/projects here
---

<BaseLayout title="Home">
  <!-- Everything here gets injected into the <slot /> of BaseLayout -->
  <div class = "layout">
    <aside class = sidebar>
      <section class = sidebar-section>
        <div class = sidebar-toggles>
          <h3> Leo Bartron </h3>
          <ToggleTheme/>
        </div>
      </section>
      <section class = sidebar-section>
        <h4> About Me </h4>
        <div class = sidebar-content>
          <p>
            I'm a current student studying computer science and software engineering! 
          </p>
        </div>
      </section>
    </aside>
    <div class = main-container>
      <div class = main-content-wrapper>
        <div class = "hero">
          <h1>Hi, I'm Leo!</h1>
          <p>This is a little information about me</p>
        </div>
        <div class = main-content-section>
          <h1>Projects</h1>
        </div>
        <div class = main-content-section>
          
        </div>
      </div>
      <footer class = "footer">

      </footer>
    </div>
  </div>
</BaseLayout>
