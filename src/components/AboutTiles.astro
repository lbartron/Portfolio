<div class = tile-wrapper>
  <div class = about-tile>
    <h3>NOW</h3>
    <p>Student Technology Consultant, UW Bothell Library</p>
  </div>
  <div class = about-tile>
    <h3>RECENTLY</h3>
    <p>Testing Quantum ML performance at the IBM Quantum Hackathon</p>
  </div>
  <div class = about-tile>
    <h3>CURRENTLY LEARNING</h3>
    <div class="tag-wrapper">
      <span class="tape-tag">Astro</span>
      <span class="tape-tag">Qiskit</span>
      <span class="tape-tag">MCP</span>
    </div>
  </div>
</div>


<style>
  .tile-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: .5rem;    
  }

  .about-tile:nth-child(1) h3{ color: var(--retro-navy); }
  .about-tile:nth-child(2) h3{ color: var(--retro-orange); }
  .about-tile:nth-child(3) h3{ color: var(--retro-red); }
  .about-tile:nth-child(4) h3{ color: var(--retro-yellow); }

  .about-tile {
    display: flex;
    flex-direction: column;
    width: 300px;
    background-color: #fff;
    margin-block: 1rem;
    padding: 1rem;

    border: 2px solid var(--border-color);
    box-shadow: 4px 4px 0px rgba(0,0,0,0.15);

    justify-content: flex-start;
    align-items: flex-start;

    border-radius: 4px 20px 10px 4px;
  }

  .about-tile h3 {
    padding: 0px;
    margin-block-start: 0em;
    margin-block-end: 1rem;

    font-style: var(--font-display);
    font-weight: 600;
    font-size: 14px;
  }

  .about-tile p {
    margin-block-start: 0em;
    margin-block-end: .5rem;
  }

  .about-tile:nth-child(even) {
    transform: rotate(2deg);
  }
  .about-tile:nth-child(odd) {
    transform: rotate(-1deg);
  }

  .tag-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-content: flex-start;
    height: 100%;
  }
</style>