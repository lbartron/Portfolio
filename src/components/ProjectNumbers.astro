---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const repoNames: string[] = [];

for (const project of allProjects) {
  if (project.data.githubUrl) {
    try {
      const { pathname } = new URL(project.data.githubUrl);
      const [, owner, repo] = pathname.split("/");
      if (owner && repo) repoNames.push(`${owner}/${repo}`);
    } catch {
      // Skip malformed URLs
    }
  }
}

const { projectCount, liveDemoCount } = Astro.props;
---

<div class = project-numbers data-repos={JSON.stringify(repoNames)}>
  <table class = project-numbers-table>
    <tbody>
      <tr>
        <td>
          <div class = pnt-cell>
            <h2 class = pnt-cell-number>{projectCount}</h2>
            <p class = pnt-cell-desc>Projects</p>
          </div>
        </td>
        <td>
          <div class = pnt-cell>
            <h2 class = pnt-cell-number>3</h2>
            <p class = pnt-cell-desc>Hackathons</p>
          </div>
        </td>
        <td>
          <div class = pnt-cell>
            <h2 class = pnt-cell-number id=commit-count>1k+</h2>
            <p class = pnt-cell-desc>Commits Created</p>
          </div>
        </td>
        <td>
          <div class = pnt-cell>
            <h2 class = pnt-cell-number>{liveDemoCount}</h2>
            <p class = pnt-cell-desc>Live Demos</p>
          </div>
        </td>
      </tr>
    </tbody>
  </table>
  <script src="../scripts/getcommitcount.js"></script>
</div>

<style>
  .project-numbers {
    width: 100%;
    container-type: inline-size;
    container-name: pnt;
  }

  .project-numbers-table {
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    table-layout: fixed;
    width: 100%;
    /* Force table to fit in box */
    box-sizing: border-box;
    background-color: light-dark(#fdfdfd, #2a2a2a);
  }

  .project-numbers-table td {
    padding: 12px 15px; 
    border-right: 1px solid var(--border-color);
    text-align: center;
    vertical-align: middle;

    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .project-numbers-table td:last-of-type {
    border-right: none;
  }

  .project-numbers-table tbody tr td:hover {
    transform: translate(-3px, -3px);
    box-shadow: 4px 4px 0px var(--retro-dark);
    border: 1px solid var(--border-color);
    border-radius: 1rem;
    border-color: var(--retro-navy);
    cursor: pointer;
  }

  .project-numbers-table td:hover {
    border-right-color: transparent;
  }

  .project-numbers-table td:has(+ td:hover) {
    border-right-color: transparent;
  }

  .pnt-cell-number {
    font-family: var(--font-display);
  }

  .project-numbers-table td:nth-child(1) .pnt-cell-number { color: var(--retro-navy); }
  .project-numbers-table td:nth-child(2) .pnt-cell-number { color: var(--retro-orange); }
  .project-numbers-table td:nth-child(3) .pnt-cell-number { color: var(--retro-red); }
  .project-numbers-table td:nth-child(4) .pnt-cell-number { color: var(--retro-yellow); }

  .pnt-cell-desc {
    
  }

  @media(max-width: 1024px) {
    /* Need to make the pnt table viewable on mobile */
    .project-numbers {
      table-layout: auto;
      box-sizing: border-box;
    }

    .project-numbers-table td {
      padding: 10px 12.5px; 
      text-align: center;
      vertical-align: middle;
    }
  }

  @container pnt (max-width: 700px) {
    .pnt-cell-number {
      font-size: 1.5rem;
    }
    .pnt-cell-desc {
      font-size: 0.75rem;
    }
  }

  @container pnt (max-width: 400px) {
    .pnt-cell-number {
      font-size: 1.15rem;
    }
    .pnt-cell-desc {
      font-size: 0.65rem;
    }
  }

  @container pnt (max-width: 320px) {
    .pnt-cell-number {
      font-size: 0.85rem;
    }
    .pnt-cell-desc {
      font-size: 0.55rem;
    }
  }
</style>