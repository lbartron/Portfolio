---
interface TimelineEvent {
  date: string;
  title: string;
  description: string;
  color?: string; // Make color optional
}

interface Props {
  title: string;
  color?: string;
  events: TimelineEvent[];
}

const { title, color = "var(--retro-red)", events = [] } = Astro.props;
---

<div class="timeline-container">
  <h2>{title}</h2>
  <div class="timeline-ruler"></div>
    {events.map((event) => (
      <div class="timeline-entry">
        <div class="timeline-node" style={`box-shadow: 4px 4px 0px ${event.color}; border-color: ${event.color};`}></div>
        <div class="timeline-content paper-card">
          <span class="timeline-date">{event.date}</span>
          <h3>{event.title}</h3>
          <p>{event.description}</p>
        </div>
      </div>
    ))}
</div>

<style>
  .timeline-container {
    position: relative;
    padding-left: 3rem; /* Room for ruler */
    margin-top: 2rem;
    height: fit-content;
  }

  .timeline-ruler {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 24px;
    border-right: 2px solid var(--retro-navy);
    
    /* Tick marks for the ruler */
    background-image: repeating-linear-gradient(
      to bottom,
      var(--retro-navy) 0,
      var(--retro-navy) 2px,
      transparent 2px,
      transparent 15px
    );
    background-size: 8px 100%;
    background-position: right top;
    background-repeat: no-repeat;
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 1rem;
  }

  /* Colored dots */
  .timeline-node {
    position: absolute;
    /* Pulling the node left to sit exactly on the ruler line */
    left: calc(-3rem + 15px); 
    top: 0.5rem;
    width: 20px;
    height: 20px;
    background: var(--bg-color);
    border: 2px solid var(--text-main);
    border-radius: 50%;
    z-index: 2;
  }

  /* Matching the retro text shadow colors */
  .node-red { box-shadow: 4px 4px 0px var(--retro-red); }
  .node-orange { box-shadow: 4px 4px 0px var(--retro-orange); }
  .node-yellow { box-shadow: 4px 4px 0px var(--retro-yellow); }

  /* 4. Content Formatting */
  .timeline-content {
    padding: .5rem;
  }

  .timeline-date {
    display: inline-block;
    font-family: var(--font-display);
    color: var(--retro-navy);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .timeline-content h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .timeline-column { 
    flex: 1; 
    min-width: 300px; 
  }
  .timeline-node { 
    background: var(--bg-color); 
    border: 2px solid; 
    border-radius: 50%; 
  }
</style>