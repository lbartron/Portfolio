---
import { Image } from 'astro:assets';

const { 
  title, description, 
  themeColor = "#0055ff", // Default fallback color
  slug, githubUrl, 
  liveUrl, detailsUrl,
  devpostUrl, image,
  featured = false,
  projectTags, } = Astro.props;
---

<div class= {` blueprint-background-container ${featured ? "is-featured" : ""} `}style={`--project-color: ${themeColor};`}>
  <div class="glass-card">
    {featured && <span class="featured-tag">Featured</span>}

    {/*Link title to project page */}
    <a href={`${import.meta.env.BASE_URL}projects/${slug}/`} class="project-title">
      <h3>{title}</h3>
    </a>
    
    <p class="project-desc">{description}</p>

    {featured && projectTags && (
      <div class="tag-wrapper">
        {projectTags.map((tag: string)  => (
          <span class="tape-tag">{tag}</span>
        ))}
      </div>
    )}

    {featured && image && (
      <div class="project-image">
        <Image src={image} alt={`${title} screenshot`}  />
      </div>
    )}
    
    <!-- Project Buttons -->
    <div class="project-links">
      
      {/* Conditionally render buttons if urls exist*/}
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="btn primary-btn">
          Launch App ↗
        </a>
      )}
      
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="btn secondary-btn">
          GitHub
        </a>
      )}

      {detailsUrl && (
        <a href={detailsUrl} target="_blank" rel="noopener noreferrer" class="btn secondary-btn">
          Details →
        </a>
      )}

      {devpostUrl && (
        <a href={devpostUrl} target="_blank" rel="noopener noreferrer" class="btn secondary-btn">
          Devpost →
        </a>
      )}
    </div>
  </div>
</div>

<style>
  /* Blueprint Background
   * Creates a graph-paper grid using linear gradients
   */
  .blueprint-background-container {
    background-color: var(--bg-color);
    background-image: 
      /* horizontal lines */
      linear-gradient(var(--retro-navy) 1px, transparent 1px),
      /* vertical lines */
      linear-gradient(90deg, var(--retro-navy) 1px, transparent 1px);
    background-size: 20px 20px; /* blueprint grid cell size */
    background-position: center;
    padding: 2rem;
    border-radius: 8px;
    border: 2px solid var(--border-color);
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;

    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .blueprint-background-container:hover {
    transform: translate(-6px, -6px);
    box-shadow: 8px 8px 0px var(--retro-dark);
    border-color: var(--retro-navy);
  }
  
  /* Pseudo-element overlay to dim the grid so text stays readable */
  .blueprint-background-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bg-color);
    opacity: 0.75; /* Adjust this to make the grid brighter or dimmer */
    z-index: 0;
  }

  /* Frosted glass effect
   * Uses backdrop-filter to blur grid lines. Contents of class
     remain unchanged.
   */
  .glass-card {
    position: relative;
    z-index: 1;
    /* Uses light-dark themes*/
    background: light-dark(rgba(255, 255, 255, 0.65), rgba(17, 17, 17, 0.75));
    backdrop-filter: blur(8px);
    padding: 1.5rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    
    /* Add support for all browsers */
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px); 
  }

  /* TITLE STYLING */
  .project-title {
    text-decoration: none;
  }

  .project-title h3 {
    margin-top: 0;
    color: var(--project-color);
    display: inline-block;
  }

  .project-title:hover h3 {
    text-decoration: underline;
  }

  .project-desc {
    color: var(--text-main);
    margin-bottom: 1.5rem;
  }

  /* BUTTON STYLING */
  .project-links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap; /* Prevents buttons from squishing on mobile */
  }

  .btn {
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .primary-btn {
    background: var(--project-color);
    color: #ffffff;
    border: 1px solid var(--project-color);
  }
  
  .primary-btn:hover {
    opacity: 0.85;
  }

  .secondary-btn {
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-main);
  }

  .secondary-btn:hover {
    border-color: var(--project-color);
    color: var(--project-color);
  }

  /* Featured Project Styling */
  .is-featured {
    width: 100%;
    height: auto;

    /* Strip blueprint background */
    margin-bottom: 0;
    padding: 0;
    border: none;
    border-radius: 0;
    background: none;
  }

  .is-featured::before {
    content: none;
  }

  .is-featured.blueprint-background-container {
    max-width: none;
    overflow: visible;
  }

  .is-featured.blueprint-background-container:hover {
    transform: translate(-6px, -6px);
    box-shadow: 8px 8px 0px var(--retro-dark);
    border-color: var(--retro-navy);
  }

  .is-featured .glass-card {
    
  }

  .is-featured .glass-card .project-title h3{
    font-size: 3rem;
    margin-block-start: 0em;
    margin-block-end: 0em;
  }

  .is-featured .glass-card .project-desc {
    font-size: 1.2rem;
    line-height: 1.6;
  }
  
  .featured-tag {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;

    /* tape-tag styling */
    background: var(--retro-yellow);
    color: #333;
    padding: 4px 12px;
    font-family: monospace;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    transform: translate(-8px, -8px) rotate(-3deg);
    box-shadow: 1px 1px 3px rgba(0,0,0,0.15);
    clip-path: polygon(2% 0, 100% 2%, 98% 100%, 0 98%);
  }

  .project-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    display: block;
    margin-bottom: 1.5rem;
  }

  .tag-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-content: flex-start;
    height: 100%;
    margin-bottom: 1.25rem;
  }

  @media (max-width: 700px) {
    .is-featured .glass-card {
      
    }
  }
</style>