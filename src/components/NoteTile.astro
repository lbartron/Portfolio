---
const { 
  title, description, 
  slug, date } = Astro.props;
---


<a href={`/notes/${slug}`} class="paper-card">
  <h3>{title}</h3>
  <p>{description}</p>
</a>

<style>
.paper-card {
  position: relative;
  display: block;
  text-decoration: none;
  color: var(--text-main);
  padding: 1.5rem;
  margin-bottom: 1rem;
  border-radius: 4px;
  border: none;
  /* Make a stacking context so ::after background stays behind the text */
  isolation: isolate;
  /* Drop shadow instead of box-shadow  */
  filter: drop-shadow(0px 0px 1px var(--border-color)) drop-shadow(0px 1px 2px rgba(0,0,0,0.05));
  transition: transform 0.2s ease, filter 0.2s ease;

  max-width: 1000px;
}

/* Main Paper Surface */
.paper-card::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: -1;
  border-radius: inherit;
  
  /* Dot Grid Background */
  background-color: light-dark(#fdfdfd, #2a2a2a);
  background-image: radial-gradient(light-dark(rgba(0,0,0,0.15), rgba(255,255,255,0.15)) 1px, transparent 1px);
  background-size: 16px 16px;
  
  /* CSS mask to cut the top-right corner */
  -webkit-mask-image: linear-gradient(225deg, transparent 20px, black 20.5px);
  mask-image: linear-gradient(225deg, transparent 20px, black 20.5px);
}

/* Styling For Folded Paper Flap */
.paper-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  
  /* 28.5px square to cover diagonal cut */
  width: 28.5px;
  height: 28.5px;
  
  /* The top-right half is transparent. The bottom-left is the folded flap. */
  background: linear-gradient(225deg, transparent 50%, var(--retro-navy) 50%);
  border-bottom-left-radius: 4px;
  box-shadow: -2px 2px 4px rgba(0,0,0,0.1);
}

.paper-card:hover {
  transform: translate(-5px, -5px);
  filter: drop-shadow(4px 4px 0px var(--retro-navy));
}

.paper-card h3 {
  margin-top: 0;
  color: var(--retro-navy);
  font-size: 1.2rem;
  font-weight: 700;
}
</style>